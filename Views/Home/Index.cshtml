@model HomeViewModel
@{
    ViewData["Title"] = Model.Title;
}

<style>
    .hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        color: #fff;
        border-radius: 12px;
        padding: 64px 48px;
        text-align: center;
        margin-bottom: 40px;
    }

    .hero h1 { font-size: 2.6rem; font-weight: 700; margin-bottom: 16px; }
    .hero h1 span { color: #f5a623; }

    .hero p {
        font-size: 1.15rem;
        color: #ccc;
        max-width: 560px;
        margin: 0 auto 32px;
        line-height: 1.7;
    }

    .badge {
        display: inline-block;
        background: #f5a623;
        color: #1a1a2e;
        font-weight: 700;
        font-size: 0.85rem;
        padding: 6px 16px;
        border-radius: 20px;
        letter-spacing: 0.5px;
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
        margin-bottom: 40px;
    }

    .card {
        background: #fff;
        border-radius: 10px;
        padding: 28px 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        border-top: 4px solid #f5a623;
    }

    .card h3 { font-size: 1.1rem; margin-bottom: 10px; color: #1a1a2e; }
    .card p { font-size: 0.92rem; color: #666; line-height: 1.6; }

    .page-builder-area {
        background: #fff;
        border-radius: 10px;
        padding: 32px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        min-height: 120px;
    }

    .rich-text-widget { line-height: 1.7; font-size: 1rem; color: #444; }
</style>

<section class="hero">
    <h1>@Model.Title <span>2.0</span></h1>
    <p>@Model.Detail</p>
    <span class="badge">Xperience by Kentico v31</span>
</section>

<div class="cards">

</div>

@* Page Builder editable area — widgets can be added here from the admin *@
<div class="page-builder-area">
    <editable-area area-identifier="main-content" />
</div>
