<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DotStark</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <page-builder-styles />
    @RenderSection("styles", required: false)
</head>
<body>

    <header class="header">
        <div class="container">
            <a href="/" class="logo">Dot<span>Stark</span></a>
            <nav>
                <a href="/services">Services</a>
                <a href="#solutions">Solutions</a>
                <a href="#process">Process</a>
                <a href="#case-studies">Case Studies</a>
                <a href="#insights">Insights</a>
            </nav>
            <a href="#contact" class="header-cta">Talk to an Expert</a>
            <button class="mobile-toggle" aria-label="Open menu">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <line x1="3" y1="12" x2="21" y2="12" />
                    <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
            </button>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="footer section-padding">
        <div class="container">
            <div class="footer-grid">
                <div class="brand">
                    <div class="logo">Dot<span>Stark</span></div>
                    <p>Engineering intelligent digital experiences with AI &amp; Kentico.</p>
                </div>
                <div class="footer-col">
                    <h4>Services</h4>
                    <ul>
                        <li><a href="#">Artificial Intelligence</a></li>
                        <li><a href="#">Kentico Development</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Solutions</h4>
                    <ul>
                        <li><a href="#">AI Agents</a></li>
                        <li><a href="#">Kentico Migration</a></li>
                        <li><a href="#">Data Platforms</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Company</h4>
                    <ul>
                        <li><a href="#">About</a></li>
                        <li><a href="#">Case Studies</a></li>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Careers</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Contact</h4>
                    <ul>
                        <li><a href="mailto:hello@dotstark.com">hello@dotstark.com</a></li>
                        <li><a href="#">LinkedIn</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year DotStark. All rights reserved.</p>
                <div class="footer-links">
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/mobileMenu.js"></script>
    <page-builder-scripts />
    @RenderSection("scripts", required: false)

</body>
</html>
